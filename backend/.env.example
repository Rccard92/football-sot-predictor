# Copia in .env e compila i valori. Mai committare segreti.

# PostgreSQL (psycopg3). Esempio locale:
# DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/serie_a_sot
DATABASE_URL=

# API-Football / API-Sports (https://www.api-football.com/)
API_FOOTBALL_KEY=
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io

# Lega e stagione predefinite (es. Serie A). Usate da ingestion e route di test admin.
DEFAULT_LEAGUE_ID=135
DEFAULT_SEASON=2025

# Baseline opzionale per feature SOT quando mancano campioni / media lega (None per disattivare).
# SOT_FEATURE_FALLBACK_BASELINE=3.0

# Origini CORS consentite (comma-separated). Obbligatorio in produzione Railway.
CORS_ORIGINS=https://frontend-production-9b20.up.railway.app,http://localhost:5173,http://localhost:3000
# Opzionale: alias aggiuntivo (unito a CORS_ORIGINS)
# FRONTEND_ORIGINS=

# SportAPI RapidAPI (solo admin/debug; non usata nel modello predittivo)
SPORTAPI_ENABLED=false
SPORTAPI_RAPIDAPI_KEY=
SPORTAPI_RAPIDAPI_HOST=sportapi7.p.rapidapi.com
SPORTAPI_BASE_URL=https://sportapi7.p.rapidapi.com
USE_SPORTAPI_LINEUPS_IN_MODEL=false
# Simulazione Lineup Impact in Audit (non modifica prediction finché false)
USE_SPORTAPI_LINEUP_IMPACT_IN_MODEL=false

# Job pre-match (Railway Cron ogni 5 min → POST /api/admin/jobs/pre-match-official-lineups/run)
ADMIN_CRON_SECRET=
PREMATCH_REFRESH_MINUTES_BEFORE=30
PREMATCH_REFRESH_WINDOW_MINUTES=10
PREMATCH_REFRESH_SKIP_RECENT_MINUTES=8
